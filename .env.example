# App mode
ENV=dev

# Log level
LOG_LEVEL=INFO

# Secrets
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_MIN=480

# User password hashes (PBKDF2 output from backend/generate_hash.py)
ADMIN_PASSWORD_HASH=pbkdf2_sha256$200000$...$...
USER_PASSWORD_HASH=pbkdf2_sha256$200000$...$...

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Storage (optional overrides)
DATA_DIR=./data
CHROMA_DIR=./data/chroma
AUDIT_LOG_PATH=./data/audit.jsonl

# Embeddings model (CPU-friendly default)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

ANONYMIZED_TELEMETRY=False 
